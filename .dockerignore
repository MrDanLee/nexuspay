# Keep the build context small and reproducible.
**/node_modules
**/dist
**/build
**/*.tsbuildinfo
**/coverage
.nyc_output

# Git / CI
.git
.github
.gitignore

# Env / secrets
.env
.env.*
!.env.example

# Editor / OS
.idea
.vscode
*.swp
*~
.DS_Store
Thumbs.db

# Local infra and docs not needed at build time
docker-compose*.yml
infra
k8s
docs
*.md
!README.md

# Logs
**/*.log
logs
