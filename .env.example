# Node
NODE_ENV=development

# Order Service
ORDER_SERVICE_PORT=3001
ORDER_DB_URL=postgres://nexuspay:nexuspay_dev@localhost:5433/nexuspay_orders

# Payment Service
PAYMENT_SERVICE_PORT=3002
PAYMENT_DB_URL=postgres://nexuspay:nexuspay_dev@localhost:5434/nexuspay_payments

# Inventory Service
INVENTORY_SERVICE_PORT=3003
INVENTORY_DB_URL=postgres://nexuspay:nexuspay_dev@localhost:5435/nexuspay_inventory

# Audit Service
AUDIT_SERVICE_PORT=3005
AUDIT_DB_URL=postgres://nexuspay:nexuspay_dev@localhost:5436/nexuspay_audit

# Notification Service
NOTIFICATION_SERVICE_PORT=3004

# RabbitMQ
RABBITMQ_URL=amqp://nexuspay:nexuspay_dev@localhost:5672

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=nexuspay-dev-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=debug